generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PayrollRecord {
  id                  String   @id @default(cuid())
  employeeId          String
  employeeName        String
  functionRole        String
  dateOfJoining       String
  department          String
  payrollMonth        String
  payrollType         String
  actualPayableDays   Float
  workingDays         Float
  lossOfPayDays       Float
  daysPayable         Float
  remunerationAmount  String
  basic               Float
  hra                 Float
  travelReimbursement Float
  specialAllowance    Float
  gross               Float
  pfEmployer          Float
  pfEmployee          Float
  professionalTax     Float
  totalDeductions     Float
  totalContributions  Float    @default(0)
  netPay              Float
  totalNetPay         Float    @default(0)
  incomeTax           Float    @default(0)
  variablePay         Float    @default(0)
  voluntaryPF         Float    @default(0)
  npsEmployer         Float    @default(0)
  loanEmi             Float    @default(0)
  cashAdvance         Float    @default(0)
  settlementAdvance   Float    @default(0)
  totalReimbursements Float    @default(0)
  monthIdentifier     String

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([employeeId, payrollMonth])
}
